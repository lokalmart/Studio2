{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "functions": {
    "api/odoo.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/assistant", "destination": "/assistant.html" },
    { "source": "/ai", "destination": "/assistant.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
